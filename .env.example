# =============================================================================
# MiaSanAI – FC Bayern AI Content Manager · Beispiel-Umgebungsvariablen
# -----------------------------------------------------------------------------
# Diese Datei dokumentiert alle unterstützten Variablen. Zur lokalen Nutzung
# als `.env.local` kopieren und mit echten Werten befüllen. NIEMALS echte
# Schlüssel committen – `.env*` ist via .gitignore ausgeschlossen (außer dieser
# Vorlage).
# =============================================================================

# --- Kern-LLM (erforderlich) -------------------------------------------------
# GEMINI_API_KEY: Pflicht für alle Gemini-Aufrufe. Ohne gültigen Schlüssel
# fällt die App auf simulierte Antworten zurück (Fallback-Engine).
GEMINI_API_KEY=""

# APP_URL: Öffentliche URL, unter der die App gehostet wird (self-referential
# Links, Callbacks). Lokal typischerweise http://localhost:3000
APP_URL=""

# --- Optionale Bild-/Videogenerierung ---------------------------------------
# Ohne diese Schlüssel greift die jeweilige Funktion auf den simulierten
# Fallback zurück.
OPENAI_API_KEY=""
LEONARDO_API_KEY=""
FAL_API_KEY=""

# --- Governance / Sicherheit -------------------------------------------------
# ADMIN_API_TOKEN: Schützt administrative Endpunkte (/api/secrets/status,
# /api/secrets/save). Als Header "x-admin-token: <TOKEN>" mitsenden. Ohne
# gesetzten Wert sind diese Endpunkte deaktiviert (fail closed).
ADMIN_API_TOKEN=""

# --- Determinismus / Reproduzierbarkeit -------------------------------------
# GEMINI_DEFAULT_TEMPERATURE: Standard-Temperature (0 = maximal deterministisch).
# Einzelne Aufrufe können den Wert explizit überschreiben.
GEMINI_DEFAULT_TEMPERATURE="0"

# GEMINI_DEFAULT_SEED: Fester Seed für reproduzierbare Ergebnisse.
GEMINI_DEFAULT_SEED="42"

# --- Betrieb / Enterprise-Konfiguration -------------------------------------
# NODE_ENV: "development" | "production" | "test".
NODE_ENV="development"

# PORT: HTTP-Port des Servers (Default 3000).
PORT="3000"

# CORS_ORIGINS: kommagetrennte Allow-Liste erlaubter Origins (leer = same-origin).
CORS_ORIGINS=""

# REQUEST_TIMEOUT_MS: Timeout je API-Request in Millisekunden (Default 30000).
REQUEST_TIMEOUT_MS="30000"

# JSON_BODY_LIMIT: max. Request-Body-Größe (base64-Medien), z.B. "25mb".
JSON_BODY_LIMIT="25mb"

# GEMINI_COST_PER_1K: Kostensatz pro 1.000 Tokens für die Usage-Kostenschätzung.
GEMINI_COST_PER_1K="0.0015"
